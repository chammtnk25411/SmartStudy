  <property name="windowTitle">
   <string>Smart Study - Bảng xếp hạng</string>
  </property>
  <property name="styleSheet">
   <string notr="true"># Dán đoạn này đè lên phần setStyleSheet cũ
        self.MainWindow.setStyleSheet(f&quot;&quot;&quot;
            /* Cửa sổ chính: Nền trắng mặc định, chữ đen */
            QMainWindow {{
                background-color: white;
                color: black;
                font-family: &quot;&quot;; /* Xóa bỏ custom font, dùng font mặc định của Qt */
            }}

            /* Bảng xếp hạng / Danh sách (QListWidget, QTableWidget) */
            QListWidget, QTableWidget {{
                background-color: white;
                color: black;
                border: 1px solid #C0C0C0; /* Viền xám mỏng mặc định */
                border-radius: 0px; /* Góc vuông, không bo tròn */
            }}

            /* Từng dòng trong danh sách */
            QListWidget::item, QTableWidget::item {{
                color: black;
                background-color: transparent;
                padding: 5px; /* Giãn cách một chút cho dễ đọc */
                border-bottom: 1px solid #F0F0F0; /* Dòng kẻ mờ ngăn cách */
            }}

            /* Khi di chuột vào dòng */
            QListWidget::item:hover, QTableWidget::item:hover {{
                background-color: #F2F2F2; /* Màu xám rất nhạt khi hover */
            }}

            /* Khi dòng được chọn (Selection) */
            QListWidget::item:selected, QTableWidget::item:selected {{
                color: white;
                background-color: #0078D7; /* Màu xanh dương mặc định của Windows */
            }}

            /* Mấy cái khác cho nó đồng bộ 'phèn' luôn */
            QLabel {{
                color: black;
                background: transparent;
            }}
            
            QPushButton {{
                background-color: #F0F0F0;
                color: black;
                border: 1px solid #A0A0A0;
                border-radius: 2px; /* Bo góc rất nhẹ của nút mặc định */
                padding: 4px 8px;
            }}
            
            QPushButton:hover {{
                background-color: #E1E1E1;
            }}
            
            QPushButton:pressed {{
                background-color: #C1C1C1;
            }}

            QLineEdit {{
                color: black;
                background-color: white;
                border: 1px solid #A0A0A0;
                border-radius: 0px;
                padding: 2px;
            }}
        &quot;&quot;&quot;)</string>
  </property>
